<Window x:Class="minhnhat_tool.DoanhNghiepWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quản lý Thông Tin Doanh Nghiệp" Height="520" Width="820"
        Icon="app.ico"
        WindowStartupLocation="CenterOwner" Background="#0b0f1a">

    <Window.Resources>
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- TRÁI: danh sách doanh nghiệp -->
        <Border Grid.Column="0" Background="#111827" CornerRadius="12" Padding="12" Margin="0,0,10,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Danh Sách Doanh Nghiệp" Foreground="#22d3ee"
                           FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                <Button DockPanel.Dock="Bottom" x:Name="btnChon" Content="Chọn doanh nghiệp này"
                        Style="{StaticResource Btn}" Background="#2563eb" Height="42" Margin="0,10,0,0"
                        Click="btnChon_Click"/>
                <ListBox x:Name="lstDN" Background="#0f172a" Foreground="#e2e8f0" BorderThickness="0"
                         FontSize="13" SelectionChanged="lstDN_SelectionChanged"/>
            </DockPanel>
        </Border>

        <!-- PHẢI: form thông tin -->
        <Border Grid.Column="1" Background="#111827" CornerRadius="12" Padding="20">
            <StackPanel>
                <TextBlock Text="Thông Tin Form" Foreground="#22d3ee" FontWeight="Bold" FontSize="14" Margin="0,0,0,16"/>

                <TextBlock Text="Mã số thuế (MST):" Foreground="#94a3b8" Margin="0,0,0,4"/>
                <TextBox x:Name="txtMst" Height="40" Background="#0f172a" Foreground="White" BorderBrush="#334155"
                         Padding="10,0" VerticalContentAlignment="Center" LostFocus="txtMst_LostFocus"/>

                <TextBlock Text="Tên doanh nghiệp (tự động lấy từ MST):" Foreground="#94a3b8" Margin="0,14,0,4"/>
                <TextBox x:Name="txtTen" Height="40" Background="#0b1220" Foreground="#94a3b8" BorderBrush="#334155"
                         Padding="10,0" VerticalContentAlignment="Center" IsReadOnly="True" Focusable="False"/>

                <TextBlock Text="Mật khẩu trang https://hoadondientu.gdt.gov.vn:" Foreground="#94a3b8" Margin="0,14,0,4"/>
                <PasswordBox x:Name="txtPassword" Height="40" Background="#0f172a" Foreground="White" BorderBrush="#334155"
                             Padding="10,0" VerticalContentAlignment="Center"/>

                <Grid Margin="0,22,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" x:Name="btnLuu" Content="Lưu" Style="{StaticResource Btn}"
                            Background="#16a34a" Height="44" Margin="0,0,6,0" Click="btnLuu_Click"/>
                    <Button Grid.Column="1" x:Name="btnXoa" Content="Xóa" Style="{StaticResource Btn}"
                            Background="#dc2626" Height="44" Margin="6,0,6,0" Click="btnXoa_Click"/>
                    <Button Grid.Column="2" x:Name="btnLamMoi" Content="Làm mới form" Style="{StaticResource Btn}"
                            Background="#374151" Height="44" Margin="6,0,0,0" Click="btnLamMoi_Click"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Window>
