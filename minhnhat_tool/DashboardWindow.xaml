<Window x:Class="minhnhat_tool.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thống kê &amp; Báo cáo" Height="720" Width="1080"
        Icon="app.ico" WindowStartupLocation="CenterOwner" Background="#0b0f1a">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="THỐNG KÊ &amp; BÁO CÁO" Foreground="#22d3ee"
                   FontWeight="Bold" FontSize="20" Margin="0,0,0,14"/>

        <!-- KPI cards -->
        <UniformGrid Grid.Row="1" Rows="1" Columns="4" Margin="0,0,0,16">
            <Border Background="#111827" CornerRadius="12" Padding="16" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Số hóa đơn" Foreground="#94a3b8" FontSize="13"/>
                    <TextBlock x:Name="kpiSoHD" Text="0" Foreground="#e2e8f0" FontSize="26" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Background="#111827" CornerRadius="12" Padding="16" Margin="8,0,8,0">
                <StackPanel>
                    <TextBlock Text="Tổng chưa thuế" Foreground="#94a3b8" FontSize="13"/>
                    <TextBlock x:Name="kpiChuaThue" Text="0" Foreground="#38bdf8" FontSize="26" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Background="#111827" CornerRadius="12" Padding="16" Margin="8,0,8,0">
                <StackPanel>
                    <TextBlock Text="Tổng thuế GTGT" Foreground="#94a3b8" FontSize="13"/>
                    <TextBlock x:Name="kpiThue" Text="0" Foreground="#34d399" FontSize="26" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Background="#111827" CornerRadius="12" Padding="16" Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock Text="Tổng thanh toán" Foreground="#94a3b8" FontSize="13"/>
                    <TextBlock x:Name="kpiThanhToan" Text="0" Foreground="#fbbf24" FontSize="26" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="420"/>
            </Grid.ColumnDefinitions>

            <!-- Biểu đồ theo tháng -->
            <Border Grid.Column="0" Background="#111827" CornerRadius="12" Padding="16" Margin="0,0,8,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Doanh thu &amp; Thuế theo tháng" Foreground="#e2e8f0"
                               FontWeight="Bold" FontSize="15" Margin="0,0,0,4"/>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                        <Border Width="12" Height="12" Background="#38bdf8" CornerRadius="2"/>
                        <TextBlock Text="Chưa thuế" Foreground="#94a3b8" Margin="4,0,14,0" FontSize="12"/>
                        <Border Width="12" Height="12" Background="#34d399" CornerRadius="2"/>
                        <TextBlock Text="Thuế GTGT" Foreground="#94a3b8" Margin="4,0,0,0" FontSize="12"/>
                    </StackPanel>
                    <ScrollViewer VerticalScrollBarVisibility="Disabled" HorizontalScrollBarVisibility="Auto">
                        <StackPanel x:Name="pnlThang" Orientation="Horizontal" VerticalAlignment="Bottom"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Top đối tác -->
            <Border Grid.Column="1" Background="#111827" CornerRadius="12" Padding="16">
                <DockPanel>
                    <TextBlock x:Name="lblTopTitle" DockPanel.Dock="Top" Text="Top 10 đối tác"
                               Foreground="#e2e8f0" FontWeight="Bold" FontSize="15" Margin="0,0,0,10"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="pnlTop"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
