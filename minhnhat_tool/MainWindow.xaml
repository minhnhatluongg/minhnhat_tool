<Window x:Class="minhnhat_tool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Phần mềm quản lý hóa đơn" Height="720" Width="1200"
        Icon="app.ico"
        WindowStartupLocation="CenterScreen" Background="#0b0f1a">

    <!-- ===== STYLE dùng chung (cho nút bo góc, dark) ===== -->
    <Window.Resources>
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2563eb"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.88"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnGreen" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="#16a34a"/>
        </Style>
        <Style x:Key="BtnOrange" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="#ea8a1e"/>
        </Style>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
        </Style>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#94a3b8"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- ===== Dark ComboBox ===== -->
        <Style x:Key="DarkComboItem" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#e2e8f0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="bd" Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#16a34a"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="Foreground" Value="#e2e8f0"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboItem}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="#0f172a" BorderBrush="#334155" BorderThickness="1" CornerRadius="6">
                                            <Path HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0"
                                                  Data="M0,0 L8,0 L4,5 Z" Fill="#94a3b8"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="12,0,28,0" VerticalAlignment="Center" IsHitTestVisible="False"/>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom"
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Border Background="#111827" BorderBrush="#334155" BorderThickness="1" CornerRadius="6"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="260" Margin="0,4,0,0">
                                    <ScrollViewer>
                                        <StackPanel IsItemsHost="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== Dark DatePicker ===== -->
        <Style TargetType="DatePickerTextBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePickerTextBox">
                        <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkDatePicker" TargetType="DatePicker">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Border Background="#0f172a" BorderBrush="#334155" BorderThickness="1" CornerRadius="6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <DatePickerTextBox x:Name="PART_TextBox" Grid.Column="0"
                                                   VerticalContentAlignment="Center" Margin="10,0,0,0"
                                                   Background="Transparent" BorderThickness="0" Foreground="White"/>
                                <Button x:Name="PART_Button" Grid.Column="1" Width="32" Focusable="False"
                                        Foreground="#94a3b8" FontSize="14" Content="📅" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="Transparent">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Popup x:Name="PART_Popup" StaysOpen="False" AllowsTransparency="True"
                                       Placement="Bottom" PlacementTarget="{Binding ElementName=PART_TextBox}"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Canh lề nội dung ô bảng -->
        <Style x:Key="CellCenter" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="CellRight" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>
    </Window.Resources>

    <Grid>
    <DockPanel Margin="14">
        <!-- ===== HEADER ===== -->
        <Border DockPanel.Dock="Top" Style="{StaticResource Card}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" x:Name="btnChonDN" Style="{StaticResource Btn}"
                        Background="#1f2937" Content="📁  Chưa chọn doanh nghiệp"
                        Click="btnChonDN_Click"/>

                <TextBlock Grid.Column="1" Text="PHẦN MỀM QUẢN LÝ HÓA ĐƠN"
                           Foreground="#22d3ee" FontSize="20" FontWeight="Bold"
                           HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,16,0"/>
            </Grid>
        </Border>

        <!-- ===== TOOLBAR (bộ lọc + hành động) ===== -->
        <Border DockPanel.Dock="Top" Style="{StaticResource Card}" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <StackPanel Margin="0,0,24,0" VerticalAlignment="Bottom">
                    <TextBlock Text="LOẠI HÓA ĐƠN" Style="{StaticResource Lbl}"/>
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="btnMuaVao" Content="Mua vào (đầu vào)" Style="{StaticResource Btn}"
                                Background="#16a34a" Width="140" Click="btnLoaiHD_Click"/>
                        <Button x:Name="btnBanRa" Content="Bán ra (đầu ra)" Style="{StaticResource Btn}"
                                Background="#1f2937" Width="130" Margin="8,0,0,0" Click="btnLoaiHD_Click"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Margin="0,0,24,0" VerticalAlignment="Bottom">
                    <TextBlock Text="KỲ KẾ TOÁN" Style="{StaticResource Lbl}"/>
                    <ComboBox x:Name="cboKy" Width="150" Style="{StaticResource DarkCombo}" SelectedIndex="0"
                              SelectionChanged="cboKy_SelectionChanged">
                        <ComboBoxItem>Theo Ngày</ComboBoxItem>
                        <ComboBoxItem>Theo Tháng</ComboBoxItem>
                        <ComboBoxItem>Theo Quý</ComboBoxItem>
                        <ComboBoxItem>Theo Năm</ComboBoxItem>
                        <ComboBoxItem>Tùy Chọn</ComboBoxItem>
                    </ComboBox>
                </StackPanel>

                <StackPanel Margin="0,0,12,0" VerticalAlignment="Bottom">
                    <TextBlock Text="TỪ NGÀY" Style="{StaticResource Lbl}"/>
                    <DatePicker x:Name="dpTuNgay" Width="140" Style="{StaticResource DarkDatePicker}"/>
                </StackPanel>

                <StackPanel Margin="0,0,24,0" VerticalAlignment="Bottom">
                    <TextBlock Text="ĐẾN NGÀY" Style="{StaticResource Lbl}"/>
                    <DatePicker x:Name="dpDenNgay" Width="140" Style="{StaticResource DarkDatePicker}"/>
                </StackPanel>

                <StackPanel Margin="0,0,12,0" VerticalAlignment="Bottom">
                    <TextBlock Text="TÌM (MST / SỐ HĐ / TÊN)" Style="{StaticResource Lbl}"/>
                    <TextBox x:Name="txtTimKiem" Width="240" Height="40"
                             Background="#0f172a" Foreground="White" BorderBrush="#334155"
                             Padding="10,0" VerticalContentAlignment="Center"
                             TextChanged="txtTimKiem_TextChanged"/>
                </StackPanel>

                <StackPanel VerticalAlignment="Bottom" Orientation="Horizontal">
                    <Button x:Name="btnTimNoiBo" Content="🔎  Tìm nội bộ" Style="{StaticResource Btn}"
                            Width="150" Click="btnTimNoiBo_Click"/>
                    <Button x:Name="btnDongBo" Content="☁  Đồng bộ Tổng cục Thuế" Style="{StaticResource BtnGreen}"
                            Width="220" Margin="10,0,0,0" Click="btnDongBo_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ===== STATUS BAR (đáy) ===== -->
        <Border DockPanel.Dock="Bottom" Style="{StaticResource Card}" Margin="0,12,0,0" Padding="16,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="lblChuaThue" Text="Chưa thuế: 0 VNĐ" Foreground="#22c55e" Margin="0,0,30,0"/>
                <TextBlock x:Name="lblThue" Text="Thuế: 0 VNĐ" Foreground="#22c55e" Margin="0,0,30,0"/>
                <TextBlock x:Name="lblTong" Text="Tổng thanh toán: 0 VNĐ" Foreground="#22c55e" Margin="0,0,30,0"/>
                <TextBlock x:Name="lblSoLuong" Text="Số lượng XML: 0/0" Foreground="#94a3b8"/>
            </StackPanel>
        </Border>

        <!-- ===== BẢNG HÓA ĐƠN (giữa, chiếm hết) ===== -->
        <Border Style="{StaticResource Card}" Padding="0">
            <DataGrid x:Name="grdHoaDon" AutoGenerateColumns="False" IsReadOnly="True"
                      SelectionMode="Extended" SelectionUnit="FullRow"
                      Background="Transparent" Foreground="#e2e8f0" BorderThickness="0"
                      RowBackground="#0f172a" AlternatingRowBackground="#131c31"
                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#1e293b"
                      HeadersVisibility="Column" FontSize="12">
                <DataGrid.Resources>
                    <Style TargetType="DataGridRow">
                        <EventSetter Event="PreviewMouseRightButtonDown" Handler="Row_RightClick"/>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="👁  Xem hóa đơn" Click="mnuXem_Click"/>
                        <MenuItem Header="📥  Tải XML gốc" Click="mnuTaiXml_Click"/>
                        <MenuItem Header="📄  Lưu PDF (mở xem rồi Ctrl+P)" Click="mnuTaiPdf_Click"/>
                        <Separator/>
                        <MenuItem Header="📊  Xuất Excel (dòng đã chọn)" Click="mnuExcelChon_Click"/>
                        <MenuItem Header="📊  Xuất Excel (tất cả)" Click="mnuExcel_Click"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#0f172a"/>
                        <Setter Property="Foreground" Value="#22c55e"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="12,12"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Trạng thái XML" Binding="{Binding TrangThaiXml}" Width="110" ElementStyle="{StaticResource CellCenter}"/>
                    <DataGridTextColumn Header="Ký hiệu"       Binding="{Binding KyHieu}"      Width="80"  ElementStyle="{StaticResource CellCenter}"/>
                    <DataGridTextColumn Header="Số HĐ"          Binding="{Binding SoHoaDon}"    Width="90"  ElementStyle="{StaticResource CellCenter}"/>
                    <DataGridTextColumn Header="Ngày lập"       Binding="{Binding NgayLap}"     Width="100" ElementStyle="{StaticResource CellCenter}"/>
                    <DataGridTextColumn Header="Người bán"      Binding="{Binding NguoiBan}"    Width="*"/>
                    <DataGridTextColumn Header="Người mua"      Binding="{Binding NguoiMua}"    Width="*"/>
                    <DataGridTextColumn Header="Chưa thuế"      Binding="{Binding TongChuaThue}" Width="120" ElementStyle="{StaticResource CellRight}"/>
                    <DataGridTextColumn Header="Thuế"           Binding="{Binding TongThue}"    Width="100" ElementStyle="{StaticResource CellRight}"/>
                    <DataGridTextColumn Header="Thanh toán"     Binding="{Binding TongThanhToan}" Width="130" ElementStyle="{StaticResource CellRight}"/>
                    <DataGridTextColumn Header="Trạng thái"     Binding="{Binding TrangThai}"   Width="120" ElementStyle="{StaticResource CellCenter}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </DockPanel>

        <!-- Overlay progress bar (hiện khi tải / xuất Excel) -->
        <Grid x:Name="overlayProgress" Background="#CC0b0f1a" Visibility="Collapsed">
            <Border Background="#16213e" CornerRadius="12" Padding="34" Width="470"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock x:Name="txtProgress" Text="Đang xử lý..." Foreground="White"
                               FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center"
                               TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,18"/>
                    <ProgressBar x:Name="barProgress" Height="20" Minimum="0" Maximum="100" Value="0"
                                 Foreground="#22c55e" Background="#0f172a" BorderThickness="0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
